# Required for Pike13 scraping (Playwright login)
PIKE13_USER=
PIKE13_PASSWORD=

# Required for S3 sync
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
TRANSCRIBE_BUCKET=

# Required for summary email
SENDER_EMAIL=
SENDER_PASSWORD=

# Optional for transcript analysis (LLM)
OPENAI_API_KEY=

# Optional overrides for MCP server (defaults to local repo + notesreminder-db/reminders.db)
# REMINDERS_DB_PATH=/Users/you/path/to/reminders.db
# REMINDERS_S3_BUCKET=notesreminder-db
# REMINDERS_S3_KEY=reminders.db
# REMINDERS_MAX_ROWS=200
